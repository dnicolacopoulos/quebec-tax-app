# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
*.egg
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Type-checker / linter caches
.mypy_cache/
.ruff_cache/
.dmypy.json

# Test caches
.pytest_cache/
.coverage
htmlcov/

# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
frontend/dist/
frontend/dist-ssr/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Docker ────────────────────────────────────────────────────────────────────
# (docker-compose.yml is versioned; overrides are not)
docker-compose.override.yml

# ── OS / Editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.suo
*.sw?

# VS Code workspace settings are versioned (.vscode/settings.json)
# but user-local files are not
.vscode/*.code-snippets
.vscode/launch.json

.idea/

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.*
*.local
